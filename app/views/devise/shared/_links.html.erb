<div class="text-center mt-2">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "ログインはこちら", new_session_path(resource_name), style: "color:#2D7D9A;font-size:16px " %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p class="text-center"><%= link_to "アカウント登録はこちら", new_registration_path(resource_name), style: "color:#2D7D9A;font-size:16px" %></p>
  <% end %>
</div>