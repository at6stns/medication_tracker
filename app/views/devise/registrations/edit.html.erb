<h2 class="fw-bold mb-4" style="font-size:24px">アカウント編集</h2>

<div class="card border-0 shadow-sm" style="max-width:560px">
  <div class="card-body p-4">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field mb-3">
        <%= f.label :avatar, "プロフィール画像", class: "form-label fw-semibold text-muted", style: "font-size:16px"%>
        <%= f.file_field :avatar , class: "form-control" %>
      </div>

      <div class="field mb-3">
        <p><%= f.label :username, "ユーザー名", class: "form-label fw-semibold text-muted", style: "font-size:16px" %></p>
        <p><%= f.text_field :username, autofocus: true, autocomplete: "username", class: "form-control" %></p>
      </div>

      <div class="field mb-3">
        <%= f.label :email, "メールアドレス", class: "form-label fw-semibold text-muted", style: "font-size:16px" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
      </div>

      <div class="field mb-3">
        <%= f.label :password, "新しいパスワード", class: "form-label fw-semibold text-muted", style: "font-size:16px" %>（変更しない場合は空白のまま）</small>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
        <% if @minimum_password_length %>
          <small><em>※<%= @minimum_password_length %>文字以上</em></small>
        <% end %>
      </div>

      <div class="field mb-3">
        <%= f.label :password_confirmation, "新しいパスワード確認", class: "form-label fw-semibold text-muted", style: "font-size:16px" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>

      <div class="field mb-4">
        <%= f.label :current_password, "現在のパスワード", class: "form-label fw-semibold text-muted", style: "font-size:16px" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
      </div>

      <div class="actions d-flex gap-2 justify-content-end">
        <%= link_to "戻る", :back, class: "btn btn-outline-secondary px-4" %>
        <%= f.submit "更新する", class: "btn fw-semibold text-white px-4", style: "background:#2D7D9A;border-radius:8px" %>
      </div>
    <% end %>
  </div>
</div>