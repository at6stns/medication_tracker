<main>
  <h2>マイページ</h2>

  <div>
    <div>
      <% if @user.avatar.attached? %>
      <%= image_tag @user.avatar, width: 120, height: 120 %>
      <% else %>
      <%= image_tag "default.png", width: 125, height: 110 %>
      <% end %>
    </div>
  </div>
    
  <div><h3><%= @user.username %></h3></div>

  <div>
    <div>
      <div><h4>基本情報</h4></div>
      <div>
       <%= link_to "アカウント編集", edit_user_registration_path, data: { turbo: false } %>
      </div>
    </div>
    
    <p>メールアドレス：<%= @user.email %></p>
    <p>ユーザー名：<%= @user.username %></p>
  </div>

</main>